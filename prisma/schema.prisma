generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Category {
  smartphones
  laptops
  monitors
  headphones
  cameras
  consoles
  watches
  accessories
}

enum Badge {
  new
  hit
  sale
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  isAdmin   Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Product {
  id          String    @id @default(cuid())
  name        String
  brand       String
  category    Category
  price       Int
  oldPrice    Int?
  emoji       String    @default("📦")
  badge       Badge?
  specs       String[]
  description String
  inStock     Boolean   @default(true)
  colors      String[]
  rating      Int       @default(5)
  reviewCount Int       @default(0)
  isStatic    Boolean   @default(false)
  createdAt   DateTime  @default(now())
  reviews     Review[]
}

model Slide {
  id         String   @id @default(cuid())
  title      String
  subtitle   String
  badge      String
  badgeColor String
  bg         String
  emoji      String
  href       String
  imageUrl   String?
  order      Int      @default(0)
  active     Boolean  @default(true)
  createdAt  DateTime @default(now())
}

model Review {
  id        String   @id @default(cuid())
  productId String
  userId    String?
  userName  String
  rating    Int
  comment   String
  createdAt DateTime @default(now())
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model Order {
  id              String      @id @default(cuid())
  orderNumber     String      @unique
  userId          String?
  customerName    String
  phone           String
  address         String
  paymentMethod   String
  status          String      @default("processing")
  trackingNumber  String?
  total           Int
  createdAt       DateTime    @default(now())
  items           OrderItem[]
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  productId String
  name      String
  emoji     String
  price     Int
  qty       Int
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
}
